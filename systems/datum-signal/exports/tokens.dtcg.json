        "components": [
          0.902,
          0.902,
          0.894
        ],
        "hex": "#e6e6e4"
      }
    },
    "up": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.082,
          0.502,
          0.239
        ],
        "hex": "#15803d"
      }
    },
    "down": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.776,
          0.157,
          0.157
        ],
        "hex": "#c62828"
      }
    }
  },
