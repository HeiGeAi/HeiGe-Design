{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "CarbonLime is a terminal-native dark system for CLI tools, cryptography, and low-level engineering. Pure carbon black (#0a0a0a) holds the void; a single electric lime (#b4ff39) is the only hue on the page while every other value stays grayscale. Monospace runs the show as display type, never decoration. Headlines, kickers, and data are all set in Space Mono. The signature is a live command line, a breathing lime block cursor trailing a mono prompt, framed by sharp zero-radius corners, hairline grids, and a static (never animated) lime glow. Terminal as interface, terminal as slide.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.706,
          1,
          0.224
        ],
        "hex": "#b4ff39"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.039,
          0.039,
          0.039
        ],
        "hex": "#0a0a0a"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.91,
          0.925,
          0.886
        ],
        "hex": "#e8ece2"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.039,
          0.039,
          0.039
        ],
        "hex": "#0a0a0a"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.075,
          0.082,
          0.071
        ],
        "hex": "#131512"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.525,
          0.553,
          0.49
        ],
        "hex": "#868d7d"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.149,
          0.165,
          0.133
        ],
        "hex": "#262a22"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.435,
          0.561,
          0.165
        ],
        "hex": "#6f8f2a"
      }
    }
  },
