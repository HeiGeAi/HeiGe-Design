    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.122,
          0.561
        ],
        "hex": "#ff1f8f"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
