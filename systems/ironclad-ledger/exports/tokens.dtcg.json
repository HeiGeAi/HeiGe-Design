    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.718,
          0.255,
          0.055
        ],
        "hex": "#b7410e"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
