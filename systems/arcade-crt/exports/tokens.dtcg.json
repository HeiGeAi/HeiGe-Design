        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "px"
        }
      }
    },
    "readout": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"VT323\", \"JetBrains Mono\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", monospace",
        "fontSize": {
          "value": 44,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 1,
          "unit": "px"
        }
      }
    },
    "button": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Press Start 2P\", \"JetBrains Mono\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 12,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 1,
          "unit": "px"
        }
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"JetBrains Mono\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", monospace",
        "fontSize": {
          "value": 12,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0.3,
          "unit": "px"
        }
      }
    },
    "eyebrow": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Press Start 2P\", \"JetBrains Mono\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 10,
          "unit": "px"
        },
