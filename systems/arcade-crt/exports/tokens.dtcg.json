{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "A phosphor-green cathode-ray design system for indie games, retro hardware, and pixel art. Everything lives inside a simulated CRT tube — static scanlines, a barrel-vignette curve, and a steady green bloom on",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.2,
          1,
          0.4
        ],
        "hex": "#33ff66"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.016,
          0.063,
          0.024
        ],
        "hex": "#041006"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.812,
          1,
          0.847
        ],
        "hex": "#cfffd8"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.024,
          0.031,
          0.024
        ],
        "hex": "#060806"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.055,
          0.082,
          0.055
        ],
        "hex": "#0e150e"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.435,
          0.682,
          0.514
        ],
        "hex": "#6fae83"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.11,
          0.227,
          0.149
        ],
        "hex": "#1c3a26"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.69,
          0
        ],
        "hex": "#ffb000"
      }
    },
    "on-accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.102,
          0.059,
          0
        ],
        "hex": "#1a0f00"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 96,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 3,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 10,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-xl": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Press Start 2P\", \"JetBrains Mono\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 52,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0.5,
          "unit": "px"
        }
      }
    },
    "display-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Press Start 2P\", \"JetBrains Mono\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 34,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0.5,
          "unit": "px"
        }
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"JetBrains Mono\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", monospace",
        "fontSize": {
          "value": 20,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0,
          "unit": "px"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
