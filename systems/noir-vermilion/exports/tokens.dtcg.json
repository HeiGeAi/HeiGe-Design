{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Noir-Vermilion is a dark editorial system for knowledge brands and long-form media. A single cut of vermilion (#CE1432) burns across a smoke-black canvas (#141210) over warm cream ink (#EDEAE3): the red never fills, it punctuates — as oversized Didone serial numbers, 8px section rules, and one full-bleed quote page that ruptures the black. Noto Serif SC carries manifesto-scale Chinese headlines; Inter keeps the body quiet and legible. Sharp corners, generous line-height, a faint 45° cross-hatch, no glow. Restraint is the luxury; the red is the only thing allowed to shout.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.808,
          0.078,
          0.196
        ],
        "hex": "#ce1432"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.969,
          0.957,
          0.929
        ],
        "hex": "#f7f4ed"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.929,
          0.918,
          0.89
        ],
        "hex": "#edeae3"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.078,
          0.071,
          0.063
        ],
        "hex": "#141210"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.11,
          0.098,
          0.086
        ],
        "hex": "#1c1916"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.604,
          0.565,
          0.51
        ],
        "hex": "#9a9082"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.204,
          0.188,
          0.169
        ],
        "hex": "#34302b"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 96,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-xl": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Playfair Display\", \"Noto Serif SC\", \"Songti SC\", \"STSong\", serif",
        "fontSize": {
          "value": 76,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.5,
          "unit": "px"
        }
      }
    },
    "display-lg": {
