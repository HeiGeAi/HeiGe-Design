{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Obsidian Flux is a dark-tech system for creative AI tools. True black #060608 is held in near-total silence and broken by a single restrained electric violet #7c5cff used only as a point of light, never as a wall of gradient. Geist and Satoshi carry sharp, tight-tracked Latin display while a mono voice numbers the data. The signature is one glowing violet core and a single 1px light edge sweeping a hairline border. Restraint is the whole idea: subtract until only the black, the white, and one violet spark remain.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.486,
          0.361,
          1
        ],
        "hex": "#7c5cff"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.02,
          0.02,
          0.024
        ],
        "hex": "#050506"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.925,
          0.918,
          0.957
        ],
        "hex": "#eceaf4"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.024,
          0.024,
          0.031
        ],
        "hex": "#060608"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.055,
          0.09
        ],
        "hex": "#0f0e17"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.545,
          0.537,
          0.612
        ],
        "hex": "#8b899c"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.137,
          0.129,
          0.188
        ],
        "hex": "#232130"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.616,
          0.518,
          1
        ],
        "hex": "#9d84ff"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 120,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 10,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-xl": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Geist, Satoshi, 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif",
        "fontSize": {
          "value": 76,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -2.4,
          "unit": "px"
        }
      }
    },
    "display-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Geist, Satoshi, 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif",
        "fontSize": {
          "value": 44,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -1.2,
          "unit": "px"
        }
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Geist, Satoshi, 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif",
        "fontSize": {
