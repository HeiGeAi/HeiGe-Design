      }
    },
    "button": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Geist, Satoshi, 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif",
        "fontSize": {
          "value": 15,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.2,
          "unit": "px"
