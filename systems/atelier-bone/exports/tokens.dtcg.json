{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "A quiet-luxury editorial system set on bone-ivory. Charcoal ink carries every word; a single thread of antique gold is spent once per view and never twice. Thin high-contrast Cormorant display plays against wide-tracked uppercase Inter labels, hairline gold rules, and full-bleed whitespace. Its signature move is restraint made visible: one drawn gold line on the page, one gilded chapter folio in the deck.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.663,
          0.545,
          0.306
        ],
        "hex": "#a98b4e"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.118,
          0.11,
          0.094
        ],
        "hex": "#1e1c18"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.2,
          0.188,
          0.169
        ],
        "hex": "#33302b"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.953,
          0.929,
          0.882
        ],
        "hex": "#f3ede1"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.98,
          0.965,
          0.925
        ],
        "hex": "#faf6ec"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.42,
          0.396,
          0.361
        ],
        "hex": "#6b655c"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.851,
          0.812,
          0.741
        ],
        "hex": "#d9cfbd"
      }
    },
    "panel": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.133,
          0.118,
          0.094
        ],
        "hex": "#221e18"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 96,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-xl": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Cormorant Garamond\", \"Cormorant\", Georgia, \"Noto Serif SC\", \"Songti SC\", \"STSong\", serif",
