{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Y2K liquid-chrome for fashion, toy, beauty and Gen-Z brands. Electric blue",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.302,
          0.357,
          1
        ],
        "hex": "#4d5bff"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.086,
          0.09,
          0.169
        ],
        "hex": "#16172b"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.922,
          0.929,
          0.961
        ],
        "hex": "#ebedf5"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.965,
          0.969,
          0.984
        ],
        "hex": "#f6f7fb"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.353,
          0.365,
          0.471
        ],
        "hex": "#5a5d78"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.788,
          0.8,
          0.831
        ],
        "hex": "#c9ccd4"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.525,
          0.816
        ],
        "hex": "#ff86d0"
      }
    },
    "on-accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.169,
          0.063,
          0.141
        ],
        "hex": "#2b1024"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 80,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-xl": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Baloo 2\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 76,
          "unit": "px"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -1.5,
          "unit": "px"
        }
      }
    },
    "display-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Baloo 2\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 52,
          "unit": "px"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -1,
          "unit": "px"
        }
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Baloo 2\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 30,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.4,
          "unit": "px"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"DM Sans\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", \"Hiragino Sans GB\", sans-serif",
        "fontSize": {
          "value": 17,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "px"
        }
      }
    },
    "body-mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Space Mono\", ui-monospace, \"SFMono-Regular\", \"Noto Sans SC\", \"PingFang SC\", monospace",
        "fontSize": {
          "value": 15,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "px"
        }
      }
    },
    "button": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Baloo 2\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 16,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.2,
          "unit": "px"
        }
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"DM Sans\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 13,
          "unit": "px"
        },
        "fontWeight": 500,
        "letterSpacing": {
          "value": 0.2,
          "unit": "px"
        }
      }
    },
    "eyebrow": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Space Mono\", ui-monospace, \"SFMono-Regular\", \"Noto Sans SC\", \"PingFang SC\", monospace",
        "fontSize": {
          "value": 12,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 2.5,
          "unit": "px"
        }
      }
    }
  }
}
