{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "An aggressively industrial, high-contrast dark system for devtools and infrastructure. Iron-black canvas, one acid-green electric voltage, concrete-gray structure. Archivo Black manifesto headlines over JetBrains Mono data, hard non-blurred offset shadows, and exposed machine-bed grid rulers. Built to boot cold and hit hard.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.784,
          1,
          0
        ],
        "hex": "#c8ff00"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.047,
          0.051,
          0.055
        ],
        "hex": "#0c0d0e"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.961,
          0.965,
          0.953
        ],
        "hex": "#f5f6f3"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.047,
          0.051,
          0.055
        ],
        "hex": "#0c0d0e"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.09,
          0.098,
          0.106
        ],
        "hex": "#17191b"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.604,
          0.616,
          0.624
        ],
        "hex": "#9a9d9f"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.192,
          0.204,
          0.216
        ],
        "hex": "#313437"
      }
    },
    "molten": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.353,
          0.122
        ],
        "hex": "#ff5a1f"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
