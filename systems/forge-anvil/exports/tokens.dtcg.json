        "value": 48,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 96,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-xl": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Archivo Black\", \"Space Grotesk\", \"Helvetica Neue\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 84,
