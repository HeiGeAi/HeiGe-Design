{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "RiotPress is an underground xerox-zine identity: hazard yellow #ffe600 slapped over photocopier black on gray copy-stock paper. Ultra-condensed all-caps display type stacks like flyposted headlines, mono stamps date every block, and crooked torn-tape labels carry the attitude. Hard offset shadows, zero radius, static half-tone grain. One token set drives both the 界面 and the 16:9 演示. No gradients, no soft corners, all bite.\n",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.902,
          0
        ],
        "hex": "#ffe600"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.043,
          0.039,
          0.024
        ],
        "hex": "#0b0a06"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.078,
          0.075,
          0.059
        ],
        "hex": "#14130f"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.906,
          0.894,
          0.855
        ],
        "hex": "#e7e4da"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.09,
          0.086,
          0.063
        ],
        "hex": "#171610"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.949,
          0.937,
          0.894
        ],
        "hex": "#f2efe4"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.341,
          0.337,
          0.302
        ],
        "hex": "#57564d"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 80,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-mega": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Anton, \"Bebas Neue\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 112,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": -1,
          "unit": "px"
        }
      }
    },
    "display-xl": {
