{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Soundwave (声浪) is a maximalist year-in-review system for music and campaign recaps, loud on purpose. Fluorescent pink",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.176,
          0.584
        ],
        "hex": "#ff2d95"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.078,
          0.059,
          0.078
        ],
        "hex": "#140f14"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.969,
          0.957,
          0.925
        ],
        "hex": "#f7f4ec"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.055,
          0.047,
          0.078
        ],
        "hex": "#0e0c14"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.106,
          0.094,
          0.149
        ],
        "hex": "#1b1826"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.678,
          0.659,
          0.737
        ],
        "hex": "#ada8bc"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.18,
          0.169,
          0.235
        ],
        "hex": "#2e2b3c"
      }
    },
    "volt": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.898,
          0
        ],
        "hex": "#ffe500"
      }
    },
    "cobalt": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.118,
          0.302,
          1
        ],
        "hex": "#1e4dff"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 80,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 3,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-xl": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Anton, \"Archivo Black\", Impact, \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 120,
          "unit": "px"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -1,
          "unit": "px"
        }
      }
    },
    "display-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Anton, \"Archivo Black\", Impact, \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 64,
          "unit": "px"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.5,
          "unit": "px"
        }
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Space Grotesk, Inter, \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 30,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.2,
          "unit": "px"
        }
      }
    },
    "eyebrow": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Space Mono, \"JetBrains Mono\", \"Noto Sans SC\", \"PingFang SC\", ui-monospace, monospace",
        "fontSize": {
          "value": 13,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 2.5,
          "unit": "px"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter, \"Helvetica Neue\", \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 17,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "px"
        }
      }
    },
    "body-mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Space Mono, \"JetBrains Mono\", ui-monospace, \"Noto Sans SC\", \"PingFang SC\", monospace",
        "fontSize": {
          "value": 15,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0.2,
          "unit": "px"
        }
      }
    },
    "button": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Space Grotesk, Inter, \"Noto Sans SC\", \"PingFang SC\", sans-serif",
        "fontSize": {
          "value": 15,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.4,
          "unit": "px"
        }
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter, \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
        "fontSize": {
          "value": 13,
          "unit": "px"
        },
        "fontWeight": 500,
        "letterSpacing": {
          "value": 0.3,
          "unit": "px"
        }
      }
    }
  }
}
