      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.847,
          0.812,
          0.745
        ],
        "hex": "#d8cfbe"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.769,
          0.153,
          0.094
        ],
        "hex": "#c42718"
      }
    }
  },
