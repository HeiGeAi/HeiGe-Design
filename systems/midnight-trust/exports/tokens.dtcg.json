          0.153,
          0.251
        ],
        "hex": "#1c2740"
      }
    },
    "steel": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.22,
          0.267,
          0.361
        ],
        "hex": "#38445c"
      }
    },
    "up": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.243,
          0.812,
          0.557
        ],
        "hex": "#3ecf8e"
