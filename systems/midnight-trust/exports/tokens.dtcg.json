        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 96,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
