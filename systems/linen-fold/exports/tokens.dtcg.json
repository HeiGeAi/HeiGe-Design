        "hex": "#f3ecdd"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.388,
          0.357,
          0.282
        ],
        "hex": "#635b48"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.839,
          0.788,
          0.682
        ],
        "hex": "#d6c9ae"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.561,
          0.325,
          0.2
        ],
        "hex": "#8f5333"
      }
    }
  },
