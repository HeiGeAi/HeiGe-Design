{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "SynthwaveDrive is HeiGe-Design's neon night-drive system. A deep violet-black canvas lit by exactly two neons, a magenta primary and an electric-cyan accent, with no third hue to dilute the glow. Tech-geometric display type wears a static double-stroke neon halo while a receding 3D grid horizon and fine scanline texture carry the atmosphere. One token set drives both a product UI and a 16:9 deck.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.184,
          0.725
        ],
        "hex": "#ff2fb9"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.071,
          0.024,
          0.122
        ],
        "hex": "#12061f"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.925,
          0.906,
          1
        ],
        "hex": "#ece7ff"
      }
    },
    "canvas": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.09,
          0.063,
          0.169
        ],
        "hex": "#17102b"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.141,
          0.102,
          0.286
        ],
        "hex": "#241a49"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.604,
          0.561,
          0.769
        ],
        "hex": "#9a8fc4"
      }
    },
    "hairline": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.204,
          0.153,
          0.373
        ],
        "hex": "#34275f"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.184,
          0.953,
          1
        ],
        "hex": "#2ff3ff"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
