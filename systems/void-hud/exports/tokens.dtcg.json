        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.2,
          "unit": "px"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "\"Inter\", system-ui, -apple-system, \"Noto Sans SC\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
